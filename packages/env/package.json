{
  "name": "@ecomx/env",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {},
  "nx": {
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}"
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bunx tsc --noEmit",
          "cwd": "{projectRoot}"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bunx eslint src/",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}
