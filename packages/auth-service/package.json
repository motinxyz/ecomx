{
  "name": "@ecomx/auth-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "dependencies": {
    "@ecomx/analytics": "workspace:*",
    "@ecomx/observability": "workspace:*"
  },
  "devDependencies": {},
  "nx": {
    "targets": {
      "serve": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun run --watch src/index.ts",
          "cwd": "{projectRoot}"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile ../../dist/auth-service src/index.ts",
          "cwd": "{projectRoot}"
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bunx tsc --noEmit",
          "cwd": "{projectRoot}"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bunx eslint src/",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}
