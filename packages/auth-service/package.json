{
  "name": "@ecomx/auth-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "dependencies": {
    "@ecomx/analytics": "workspace:*",
    "@ecomx/env": "workspace:*",
    "@ecomx/infra": "workspace:*",
    "@ecomx/observability": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "zod": "^3.25.0",
    "elysia": "^1.4.28"
  },
  "devDependencies": {},
  "nx": {
    "targets": {
      "serve": {
        "executor": "nx:run-commands",
        "options": {
          "command": "OTEL_SERVICE_NAME=auth-service bun run --preload @ecomx/observability/instrumentation --watch src/index.ts | bunx pino-pretty",
          "cwd": "{projectRoot}"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun test",
          "cwd": "{projectRoot}"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile ../../dist/auth-service src/index.ts",
          "cwd": "{projectRoot}"
        }
      },
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bunx tsc --noEmit",
          "cwd": "{projectRoot}"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bunx eslint src/",
          "cwd": "{projectRoot}"
        }
      }
    }
  }
}
